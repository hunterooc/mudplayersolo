# OpenAI API key for MH, PH, DH, VH
OPENAI_API_KEY=

# MUD connection (telnet)
MUD_HOST=
MUD_PORT=

# MUD login (optional; if set, client runs: name => password => enter => 1)
# MUD_CHARACTER=
# MUD_PASSWORD=

# Hugging Face token (for WM model download; optional if already logged in via huggingface-cli)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: paths and model overrides
# DATA_DIR=data
# WM_CHECKPOINT_DIR=data/checkpoints/wm
# OPENAI_MODEL=
# SILENCE_TIMEOUT_SEC=10
